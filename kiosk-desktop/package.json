{
  "name": "ccs-hrms-kiosk-desktop",
  "version": "1.0.0",
  "description": "CCS HRMS Desktop Kiosk — Attendance for Windows & Mac",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.ccshrms.kiosk",
    "productName": "CCS HRMS Kiosk",
    "copyright": "Copyright © 2026 CCS HRMS",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64", "ia32"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "CCS HRMS Kiosk"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "darkModeSupport": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.0"
  }
}
